-- ========================================================
-- FUNZIONI INTERNE ORIGINALI
-- ========================================================
local function ClaimReward()
    local Players = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local TargetPlayer = Players:FindFirstChild("xnxsmoke2") or Players.LocalPlayer
    
    local RemoteStorage = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Network"):WaitForChild("RemoteEventStorage")
    local ClaimRewardEvent = RemoteStorage:WaitForChild("ClaimDailyReward")
    
    if TargetPlayer then
        ClaimRewardEvent:FireServer(unpack({ TargetPlayer }))
    end
end

local function ResetStreak()
    local Players = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local TargetPlayer = Players:FindFirstChild("xnxsmoke2") or Players.LocalPlayer
    
    local RemoteStorage = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Network"):WaitForChild("RemoteEventStorage")
    local ResetStreakEvent = RemoteStorage:WaitForChild("ResetDailyStreak")
    
    if TargetPlayer then
        ResetStreakEvent:FireServer(unpack({ TargetPlayer }))
    end
end

local function GiveWin()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local RemoteStorage = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Network"):WaitForChild("RemoteEventStorage")
    local ThrowRewardEvent = RemoteStorage:WaitForChild("ThrowReward")
    
    ThrowRewardEvent:FireServer(unpack({ 0 }))
end

local function TrainClick()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local RemoteStorage = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Network"):WaitForChild("RemoteEventStorage")
    local JuggleClickEvent = RemoteStorage:WaitForChild("JuggleClick")
    
    JuggleClickEvent:FireServer()
end

-- ========================================================
-- FUNZIONE DI APERTURA RAPIDA CON QUANTITÀ DINAMICA
-- ========================================================
local function HatchNightmare(quantita)
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Comm = require(ReplicatedStorage.Packages.Comm)
    local nomeUovo = "Nightmare Egg"
    
    if Comm and Comm.RemoteSignal then
        local openSignal = Comm.RemoteSignal.ExclusiveOpen
        if openSignal then
            openSignal:FireServer(nomeUovo, quantita)
            
            if Comm.RemoteSignal.ExclusiveEggAnimationFinished then
                task.wait(0.05)
                Comm.RemoteSignal.ExclusiveEggAnimationFinished:FireServer()
            end
        end
    end
end

-- ========================================================
-- TAB 1: FUNZIONI ED AUTOMATION
-- ========================================================

local RewardToggle = Tabs.Funzioni:AddToggle("ToggleReward", {Title = "Spam Reward & Reset", Default = false })
local RewardSpammerAttivo = false

RewardToggle:OnChanged(function()
    RewardSpammerAttivo = RewardToggle.Value
    if RewardSpammerAttivo then
        task.spawn(function()
            while RewardSpammerAttivo do
                pcall(ClaimReward)
                task.wait(0.1)
                if not RewardSpammerAttivo then break end
                pcall(ResetStreak)
                task.wait(0.1)
            end
        end)
    end
end)

local WinsToggle = Tabs.Funzioni:AddToggle("ToggleWins", {Title = "Inf Wins", Default = false })
local WinsSpammerAttivo = false

WinsToggle:OnChanged(function()
    WinsSpammerAttivo = WinsToggle.Value
    if WinsSpammerAttivo then
        task.spawn(function()
            while WinsSpammerAttivo do
                pcall(GiveWin)
                task.wait(0.1)
            end
        end)
    end
end)

local TrainToggle = Tabs.Funzioni:AddToggle("ToggleTrain", {Title = "Auto Train", Default = false })
